<?xml version="1.0" encoding="utf-8"?>
<!-- Ничего не отдаём ни в облачный бэкап, ни в перенос между устройствами:
     список сайтов, логины и шифртекст сейфа - не для чужих облаков. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
